{
  "name": "pets",
  "version": "0.1.0",
  "private": true,
  "description": "Pet Mobility Agent monorepo.",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "mobile:start": "pnpm --filter @pets/mobile start",
    "mobile:ios": "pnpm --filter @pets/mobile ios",
    "web:dev": "pnpm --filter @pets/web dev",
    "web:build": "pnpm --filter @pets/web build",
    "typecheck": "pnpm -r --if-present run typecheck"
  },
  "devDependencies": {
    "typescript": "~6.0.3"
  }
}
