{
  "name": "pets",
  "version": "0.1.0",
  "private": true,
  "description": "Pet Mobility Agent monorepo.",
  "packageManager": "npm@10.9.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile:start": "npm run start -w @pets/mobile",
    "mobile:ios": "npm run ios -w @pets/mobile",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "~6.0.3"
  }
}
