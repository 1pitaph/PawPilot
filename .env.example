# Avatar Pipeline API
AVATAR_API_HOST=127.0.0.1
AVATAR_API_PORT=4317
AVATAR_API_PUBLIC_BASE_URL=http://127.0.0.1:4317
AVATAR_PROVIDER_MODE=auto
AVATAR_MOCK_ON_PROVIDER_FAILURE=true

# GPT-Image-2 via APIMart
APIMART_API_KEY=
APIMART_BASE_URL=https://api.apimart.ai/v1
APIMART_GPT_IMAGE_2_RESOLUTION=1k
APIMART_POLL_INTERVAL_MS=3000
APIMART_POLL_TIMEOUT_MS=600000

# Tripo OpenAPI
TRIPO_API_KEY=
TRIPO_BASE_URL=https://api.tripo3d.ai
TRIPO_MODEL_VERSION=P1-20260311
TRIPO_RIG_VERSION=v2.5-20260210
TRIPO_POLL_INTERVAL_MS=2500
TRIPO_POLL_TIMEOUT_MS=900000

# Expo mobile app
EXPO_PUBLIC_AVATAR_API_URL=http://127.0.0.1:4317
